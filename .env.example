# ========================================================================
# Configuração de Ambiente - aDiarista
# ========================================================================
#
# ⚠️ SEGURANÇA - LEIA ANTES DE USAR:
# 
# ✅ ANON KEY: Pode ser exposta (protegida por RLS)
# ❌ SERVICE KEY: NUNCA exponha no frontend ou Git!
# 
# Veja SECURITY.md para guia completo de segurança
#
# ========================================================================

## Variáveis necessárias

# Supabase (OBRIGATÓRIO)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anonima-aqui
# ⚠️ SERVICE KEY - Use apenas em backend/cloud functions
# SUPABASE_SERVICE_KEY=sua-chave-service-aqui

# Google Maps (Opcional)
GOOGLE_MAPS_API_KEY=sua-chave-google-maps

# Stripe/Payment (Futuro)
STRIPE_PUBLISHABLE_KEY=seu-stripe-key
# ⚠️ SECRET KEY - NUNCA exponha no frontend!
# STRIPE_SECRET_KEY=seu-stripe-secret

# Ambiente
ENVIRONMENT=development
# Valores possíveis: development, staging, production

# Logging
LOG_LEVEL=debug
# Valores possíveis: debug, info, warning, error

# Feature Flags
FEATURE_MAPS=false
FEATURE_PAYMENT=false
FEATURE_REALTIME=false

## Como usar:

# 1. Copie este arquivo para .env
#    cp .env.example .env

# 2. Preencha com suas credenciais reais

# 3. NUNCA commit .env (já está no .gitignore)

# 4. Para desenvolvimento local, use:
#    flutter pub global activate flutter_dotenv
#    flutter run --dart-define-from-file=.env

# ========================================================================
# ⚠️ NUNCA exponha estas chaves em repositórios públicos!
# ⚠️ Rotacione chaves comprometidas imediatamente!
# ========================================================================
